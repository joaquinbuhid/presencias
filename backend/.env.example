# ============================================================
# CONFIGURACION - copiar a .env y completar con tus datos
# ============================================================

# Base de datos MySQL (Hostinger)
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql
DB_NAME=seguridad_asistencias

# JWT - cambiar por una cadena larga y aleatoria
JWT_SECRET=cambiar_por_clave_secreta_larga_aleatoria_2024
JWT_EXPIRES_IN=12h

# Servidor
PORT=3000
NODE_ENV=production

# CORS - dominio de tu frontend (sin barra final)
FRONTEND_URL=https://tu-dominio.com
